# Copy to .env and fill in. .env is gitignored.

# Provider API key (Gemini)
GEMINI_API_KEY=

# Optional: where ARC lives. One env var, full path. Tilde + $VARS expanded.
# Default if unset: ~/.arc
# Examples:
#   ARC_HOME=~/.arc
#   ARC_HOME=~/Projects/p1/.arc
#   ARC_HOME=/abs/path/to/anywhere
# ARC_HOME=
